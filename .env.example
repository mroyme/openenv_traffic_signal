# LLM API endpoint (e.g. https://api.openai.com/v1)
API_BASE_URL=

# Model identifier (e.g. gpt-4o, meta-llama/Llama-3.3-70B-Instruct)
MODEL_NAME=

# API key (Hugging Face token or OpenAI key depending on API_BASE_URL)
HF_TOKEN=

# Traffic signal environment URL (defaults to http://localhost:8000)
TRAFFIC_ENV_URL=http://localhost:8000
